# renas copia este archivo a .env.local y rellenar los valores antes de correr la app.
# cp .env.example .env.local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# Groq API (gratuito — conseguir key en https://console.groq.com)
GROQ_API_KEY=gsk_...

# Cron secret (protege el endpoint /api/ingest en producción)
# Generar con: openssl rand -hex 32
CRON_SECRET=genera_un_string_aleatorio_largo_aqui
